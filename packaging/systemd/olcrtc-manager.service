[Unit]
Description=olcrtc manager
Documentation=https://github.com/openlibrecommunity/olcrtc-manager
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=olcrtc
Group=olcrtc
Environment=OLCRTC_PATH=/usr/local/bin/olcrtc
ExecStart=/usr/local/bin/olcrtc-manager -config /etc/olcrtc-manager/config.json
ExecReload=/bin/kill -HUP $MAINPID
Restart=on-failure
RestartSec=5s
KillSignal=SIGTERM
TimeoutStopSec=10s

[Install]
WantedBy=multi-user.target
